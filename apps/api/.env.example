NODE_ENV=development
PORT=4000

# Postgres na nuvem (Neon/Supabase). Exemplo Supabase, pooler em modo SESSION
# (porta 5432) — recomendado aqui porque a API e um servidor Node persistente
# (nao serverless): o modo session deixa a conexao TCP/TLS reaberta e reutilizada
# entre queries. O modo transaction (porta 6543, com "?pgbouncer=true") existe
# pra clientes serverless que abrem muitas conexoes curtas; usado nesta API,
# cada query reabre a conexao do zero (handshake TLS ~700ms observado), deixando
# toda a navegacao visivelmente lenta:
DATABASE_URL="postgresql://postgres.xxxx:senha@aws-0-us-east-1.pooler.supabase.com:5432/postgres"
# Mesma pooler em modo session, usada pelo Prisma Migrate (precisa de prepared
# statements, que o modo transaction nao suporta).
DIRECT_URL="postgresql://postgres.xxxx:senha@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# Gere segredos fortes, ex: openssl rand -base64 48
JWT_ACCESS_SECRET="troque-por-um-segredo-forte-de-32-caracteres-ou-mais"
JWT_REFRESH_SECRET="troque-por-outro-segredo-forte-de-32-caracteres-ou-mais"
COOKIE_SECRET="troque-por-outro-segredo-forte-de-32-caracteres-ou-mais"

# Origem do frontend (para CORS + cookie)
WEB_ORIGIN="http://localhost:3000"

UPLOADS_DIR="uploads"

# Caminho do executavel ffmpeg/ffprobe. Se estiver no PATH, deixe apenas "ffmpeg"/"ffprobe".
FFMPEG_PATH="ffmpeg"
FFPROBE_PATH="ffprobe"
TRANSCODE_CONCURRENCY=1
TRANSCODE_TIMEOUT_MINUTES=60

# Armazenamento de midia: "local" grava em UPLOADS_DIR e serve via /media (padrao,
# bom para dev). "s3" publica HLS/thumbnails/legendas num bucket compativel com S3
# (Supabase Storage, Backblaze B2, Cloudflare R2 etc) - use em producao, pois o
# disco local de plataformas como Railway/Render nao e persistente entre deploys.
STORAGE_DRIVER="local"

# Preenchidos apenas quando STORAGE_DRIVER=s3. Exemplo Supabase Storage (bucket "media" publico):
# S3_ENDPOINT="https://<project-ref>.storage.supabase.co/storage/v1/s3"
# S3_PUBLIC_URL_BASE="https://<project-ref>.supabase.co/storage/v1/object/public/media"
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL_BASE=""
S3_FORCE_PATH_STYLE=true

# Google Cloud Translation API (Basic/v2) - usada pelo botao "Traduzir automaticamente"
# nos formularios de cadastro. Gere uma API key no mesmo projeto GCP ja usado
# para o Compute Engine, com a Cloud Translation API habilitada.
GOOGLE_TRANSLATE_API_KEY=""
